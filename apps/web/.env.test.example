# Supabase — get these from your Supabase project dashboard → Settings → API
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Mock auth mode (default for E2E). Set to "true" to bypass real Supabase Auth.
# Page/render/navigation tests use this. Real auth tests require this to be "false".
VITE_ENABLE_MOCK_AUTH=true

# E2E test user — only needed for real-auth tests (login, logout, redirect).
# When set, real-auth tests become active. Supabase Auth + a profiles row must exist.
E2E_USER_EMAIL=test@example.com
E2E_USER_PASSWORD=your-test-password
